# HTTP redirect
server {
    listen 80;
    listen [::]:80;
    server_name hermes-agent-hcd1.srv1626925.hstgr.cloud
                hermes-agent-egew.srv1626925.hstgr.cloud
                hermes-agent-ftjd.srv1626925.hstgr.cloud;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name hermes-agent-hcd1.srv1626925.hstgr.cloud;

    ssl_certificate /etc/letsencrypt/live/hermes-agent-hcd1.srv1626925.hstgr.cloud/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hermes-agent-hcd1.srv1626925.hstgr.cloud/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://127.0.0.1:14861;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
    }
}

